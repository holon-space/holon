ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/bitsdojo_window_macos" "${PODS_CONFIGURATION_BUILD_DIR}/desktop_webview_window" "${PODS_CONFIGURATION_BUILD_DIR}/file_picker" "${PODS_CONFIGURATION_BUILD_DIR}/flutter_web_auth_2" "${PODS_CONFIGURATION_BUILD_DIR}/macos_secure_bookmarks" "${PODS_CONFIGURATION_BUILD_DIR}/macos_window_utils" "${PODS_CONFIGURATION_BUILD_DIR}/path_provider_foundation" "${PODS_CONFIGURATION_BUILD_DIR}/rust_lib_holon" "${PODS_CONFIGURATION_BUILD_DIR}/shared_preferences_foundation" "${PODS_CONFIGURATION_BUILD_DIR}/url_launcher_macos" "${PODS_CONFIGURATION_BUILD_DIR}/window_to_front"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/bitsdojo_window_macos/bitsdojo_window_macos.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/desktop_webview_window/desktop_webview_window.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/file_picker/file_picker.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/flutter_web_auth_2/flutter_web_auth_2.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/macos_secure_bookmarks/macos_secure_bookmarks.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/macos_window_utils/macos_window_utils.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/path_provider_foundation/path_provider_foundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/rust_lib_holon/rust_lib_holon.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/shared_preferences_foundation/shared_preferences_foundation.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/url_launcher_macos/url_launcher_macos.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/window_to_front/window_to_front.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/../Frameworks' '@loader_path/Frameworks' "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}"
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)/ $(SDKROOT)/usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "bitsdojo_window_macos" -framework "desktop_webview_window" -framework "file_picker" -framework "flutter_web_auth_2" -framework "macos_secure_bookmarks" -framework "macos_window_utils" -framework "path_provider_foundation" -framework "rust_lib_holon" -framework "shared_preferences_foundation" -framework "url_launcher_macos" -framework "window_to_front"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/FlutterMacOS" "-F${PODS_CONFIGURATION_BUILD_DIR}/bitsdojo_window_macos" "-F${PODS_CONFIGURATION_BUILD_DIR}/desktop_webview_window" "-F${PODS_CONFIGURATION_BUILD_DIR}/file_picker" "-F${PODS_CONFIGURATION_BUILD_DIR}/flutter_web_auth_2" "-F${PODS_CONFIGURATION_BUILD_DIR}/macos_secure_bookmarks" "-F${PODS_CONFIGURATION_BUILD_DIR}/macos_window_utils" "-F${PODS_CONFIGURATION_BUILD_DIR}/path_provider_foundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/rust_lib_holon" "-F${PODS_CONFIGURATION_BUILD_DIR}/shared_preferences_foundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/url_launcher_macos" "-F${PODS_CONFIGURATION_BUILD_DIR}/window_to_front"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
